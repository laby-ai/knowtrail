# Public deployment
PORT=5000
DEPLOY_RUN_PORT=5000
APP_RUNTIME_ENV=production
NEXT_PUBLIC_DOMAIN=localhost:5000

# Public upload guards. Defaults are 25MB per file and 5 files per request.
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_FILES=5

# Optional internal origin used when upload flows call this app's OCR/analyze APIs.
# Leave empty for ordinary single-process localhost deployment; set on platforms
# where the app must call itself through a specific private/public origin.
INTERNAL_APP_ORIGIN=

# Virtual classroom runtime. In Linux packages the bundled classroom runtime is
# exposed through the app so the browser never sees a localhost iframe URL.
NEXT_PUBLIC_VIRTUAL_CLASSROOM_ORIGIN=/classroom-runtime
VIRTUAL_CLASSROOM_INTERNAL_ORIGIN=http://127.0.0.1:5025/classroom-runtime
OPENMAIC_SIDECAR_HOST=127.0.0.1
OPENMAIC_SIDECAR_PORT=5025

# Optional account and billing center integration. Public URL should point to
# the ordinary application portal, not the administrator registration screen.
ACCOUNT_CENTER_PUBLIC_URL=
NEXT_PUBLIC_ACCOUNT_CENTER_URL=
ACCOUNT_CENTER_API_BASE=
ACCOUNT_CENTER_TENANT_ID=
ACCOUNT_CENTER_DEFAULT_MEMBER_ID=
ACCOUNT_CENTER_APP_KEY=
ACCOUNT_CENTER_CREDENTIAL_KEY=
ACCOUNT_CENTER_CLIENT_SECRET=
ACCOUNT_CENTER_PRODUCT_AREA=ai.text
# Optional override if the account service exposes a different password reset endpoint.
ACCOUNT_CENTER_PASSWORD_RESET_PATH=/v1/auth/password-reset/request
# Set true in C-end deployments so AI calls require a logged-in account token.
ACCOUNT_CENTER_REQUIRE_AUTH=false

# Account-bound model service. C-end users do not enter API Base or API Key in
# the browser; requests use these deployment secrets or an approved gateway.
OPENAI_COMPAT_API_BASE=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini
OPENAI_COMPAT_VISION_MODEL=
OPENAI_COMPAT_IMAGE_API_BASE=
OPENAI_COMPAT_IMAGE_API_KEY=
OPENAI_COMPAT_IMAGE_MODEL=
OPENAI_COMPAT_EMBEDDING_MODEL=text-embedding-3-small
# Optional real connection-test guardrails. Increase text timeout for providers
# that can be slow on first request.
AI_TEST_CONFIG_TEXT_TIMEOUT_MS=45000
AI_TEST_CONFIG_VISION_TIMEOUT_MS=60000
AI_TEST_CONFIG_EMBEDDING_TIMEOUT_MS=30000
# Ark aliases accepted by pnpm smoke:real-openai-compatible:
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6-251015
# ARK_IMAGE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_API_KEY=
# ARK_IMAGE_MODEL=doubao-seedream-5-0-lite-260128
# ARK_EMBEDDING_MODEL=
# Public deployments block HTTP, localhost, and private-network API Base values by default.
# Keep both false unless you intentionally run a trusted internal gateway.
ALLOW_INSECURE_API_BASE=false
ALLOW_PRIVATE_API_BASE=false

# Local production-grade vector store. Zvec is an in-process vector database
# with WAL persistence; keep this path on persistent disk in production.
ZVEC_STORE_PATH=.data/zvec

# Local source/chunk metadata store used by the ingestion pipeline. Keep this
# file on the same persistent disk as ZVEC_STORE_PATH in single-node production.
SOURCE_STORE_ADAPTER=local-json
SOURCE_STORE_PATH=.data/sources/sources.json
STUDIO_JOB_STORE_PATH=.data/studio-jobs/jobs.json
# Generated scientific illustrations must survive application releases.
SCIENTIFIC_ILLUSTRATION_STORE_DIR=.data/scientific-illustrations
# Optional shared source store for multi-instance deployments.
# Set SOURCE_STORE_ADAPTER=postgres and provide DATABASE_URL to store source
# metadata in Postgres. The adapter keeps lingbi_source_store as a jsonb
# compatibility snapshot and mirrors production query tables:
# lingbi_sources, lingbi_source_chunks, lingbi_ingestion_stages.
DATABASE_URL=
# Optional Postgres ready chunk search mode. Default "ilike" keeps conservative
# behavior for Chinese-heavy documents. Set "fts" to rank candidates with the
# lingbi_source_chunks_fts_idx GIN index and ts_rank for ASCII/token-heavy text.
POSTGRES_READY_CHUNK_SEARCH=ilike
# Optional disposable Postgres URL for pnpm smoke:postgres-source-store.
# This must be a dedicated smoke/test database. The script uses a transaction
# and rollback, but it intentionally refuses to use DATABASE_URL implicitly.
POSTGRES_SMOKE_DATABASE_URL=

# Optional async podcast status endpoint. Use {taskId} as the upstream task id
# placeholder when a provider returns a task instead of audio.
PODCAST_STATUS_URL_TEMPLATE=

# Optional real podcast provider. This is the VolcEngine/ByteDance Doubao
# Podcast WebSocket v3 API, not the legacy one-shot TTS endpoint. Keep the
# access key private; for real smoke tests prefer .env.real.local.
VOLCENGINE_PODCAST_WS_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sami/podcasttts
VOLCENGINE_PODCAST_APP_ID=
VOLCENGINE_PODCAST_ACCESS_KEY=
VOLCENGINE_PODCAST_RESOURCE_ID=volc.service_type.10050
VOLCENGINE_PODCAST_APP_KEY=aGjiRDfUWi
VOLCENGINE_PODCAST_SPEAKERS=zh_male_dayixiansheng_v2_saturn_bigtts,zh_female_mizaitongxue_v2_saturn_bigtts
VOLCENGINE_PODCAST_FORMAT=mp3
VOLCENGINE_PODCAST_SAMPLE_RATE=24000
VOLCENGINE_PODCAST_TIMEOUT_MS=180000

# Default real podcast audio path: Doubao AgentPlan TTS. The official endpoint
# domain is openspeech.bytedance.com, but product/runtime config uses the
# AgentPlan/Doubao names below.
AGENTPLAN_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
AGENTPLAN_TTS_RESOURCE_ID=seed-tts-2.0
AGENTPLAN_TTS_API_KEY=
AGENTPLAN_TTS_SPEAKER=
AGENTPLAN_TTS_FORMAT=mp3
AGENTPLAN_TTS_SAMPLE_RATE=24000
AGENTPLAN_TTS_TIMEOUT_MS=90000

# File storage. Default local keeps uploads in public/uploads and works for
# single-node deploys with a persistent disk. Set FILE_STORAGE_ADAPTER=s3 for
# S3-compatible object storage.
FILE_STORAGE_ADAPTER=local
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional PDF figure extraction.
MINERU_API_TOKEN=
# MinerU background job guardrails. Defaults: 180s timeout, 1 retry, 3s delay.
MINERU_JOB_TIMEOUT_MS=180000
MINERU_JOB_MAX_RETRIES=1
MINERU_JOB_RETRY_DELAY_MS=3000

# Optional external slide-image generation service used by legacy PPT flow.
SITIAN_API_BASE=http://images.sitianai.com
SITIAN_API_TOKEN=
