# Public deployment
PORT=5000
DEPLOY_RUN_PORT=5000
NEXT_PUBLIC_DOMAIN=localhost:5000
APP_RUNTIME_ENV=production

# Public upload guards
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_FILES=5
INTERNAL_APP_ORIGIN=

# Virtual classroom runtime. The public origin stays same-site; start.sh
# starts the bundled classroom runtime and proxies it through the app.
NEXT_PUBLIC_VIRTUAL_CLASSROOM_ORIGIN=/classroom-runtime
VIRTUAL_CLASSROOM_INTERNAL_ORIGIN=http://127.0.0.1:5025/classroom-runtime
OPENMAIC_SIDECAR_HOST=127.0.0.1
OPENMAIC_SIDECAR_PORT=5025

# Account-bound model service. C-end users do not enter model API keys.
OPENAI_COMPAT_API_BASE=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini
OPENAI_COMPAT_VISION_MODEL=
OPENAI_COMPAT_EMBEDDING_MODEL=text-embedding-3-small
ALLOW_INSECURE_API_BASE=false
ALLOW_PRIVATE_API_BASE=false

# Persistent storage. Keep these directories on a server disk or mounted volume.
ZVEC_STORE_PATH=/opt/lingbi-studio/.data/zvec
SOURCE_STORE_ADAPTER=local-json
SOURCE_STORE_PATH=/opt/lingbi-studio/.data/sources/sources.json
STUDIO_JOB_STORE_PATH=/opt/lingbi-studio/.data/studio-jobs/jobs.json
SCIENTIFIC_ILLUSTRATION_STORE_DIR=/opt/lingbi-studio/.data/scientific-illustrations

# Multi-instance deployments should use Postgres instead of local-json.
DATABASE_URL=
POSTGRES_READY_CHUNK_SEARCH=ilike
POSTGRES_SMOKE_DATABASE_URL=

# File storage. Default local requires a persistent server disk. Set s3 for
# S3-compatible object storage in multi-instance or stateless deployments.
FILE_STORAGE_ADAPTER=local
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional MinerU and podcast integrations
MINERU_API_TOKEN=
MINERU_JOB_TIMEOUT_MS=180000
MINERU_JOB_MAX_RETRIES=1
MINERU_JOB_RETRY_DELAY_MS=3000
PODCAST_STATUS_URL_TEMPLATE=
AGENTPLAN_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
AGENTPLAN_TTS_RESOURCE_ID=seed-tts-2.0
AGENTPLAN_TTS_API_KEY=
AGENTPLAN_TTS_SPEAKER=
AGENTPLAN_TTS_FORMAT=mp3
AGENTPLAN_TTS_SAMPLE_RATE=24000
AGENTPLAN_TTS_TIMEOUT_MS=90000

# Optional legacy image generation service
SITIAN_API_BASE=http://images.sitianai.com
SITIAN_API_TOKEN=
